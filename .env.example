# ============================================
# Multi-Provider Place Search Configuration
# ============================================
# 
# This application uses multiple place search providers to ensure reliability and coverage:
# 1. Nominatim (OpenStreetMap) → PRIMARY search provider (free, no key required)
# 2. Geoapify → SECONDARY provider for enrichment (phone, website)
# 3. SerpApi → FALLBACK provider for additional results or enrichment
#
# Flow:
# - User searches for restaurant
# - Nominatim returns locations
# - On selection, Geoapify enriches with phone/website
# - If Geoapify has gaps, SerpApi fills in missing data

# ============================================
# Geoapify API Key (RECOMMENDED)
# ============================================
# Used for enriching place data with phone numbers and websites
# Sign up at: https://www.geoapify.com/
# Get your free API key from: https://myprojects.geoapify.com/
# Free tier: 3,000 API calls/day (sufficient for most use cases)
GEOAPIFY_KEY=

# ============================================
# SerpApi API Key (OPTIONAL)
# ============================================
# Used as fallback to get additional results or fill missing phone/website
# Sign up at: https://serpapi.com/
# Get your API key from: https://serpapi.com/manage/account
# Note: Has API limits, use for fallback only
SERPAPI_KEY=

# ============================================
# Google Maps Server Key (NOT USED BY DEFAULT)
# ============================================
# Set this only if you want Google Places as an additional provider
# Get from: https://console.cloud.google.com/
# Leave empty to use only Nominatim/Geoapify/SerpApi
GOOGLE_MAPS_SERVER_KEY=

# Public Google Places key (NOT USED BY DEFAULT)
# Leave empty unless using Google Places autocomplete
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# ============================================
# Place Search Configuration
# ============================================
# Default country code for place searches (ISO 3166-1 alpha-2)
# Default: 'za' (South Africa)
# Examples: 'us' (USA), 'gb' (UK), 'au' (Australia), 'ca' (Canada)
PLACE_SEARCH_COUNTRY=za
